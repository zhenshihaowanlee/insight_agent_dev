{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenRouterModelResponse",
  "type": "object",
  "required": [
    "response_id",
    "request_id",
    "created_at",
    "dry_run",
    "provider",
    "model_id",
    "stage",
    "status",
    "output",
    "usage",
    "cost",
    "budget_status",
    "processing_allowed",
    "manual_required",
    "error",
    "redaction",
    "metadata"
  ],
  "properties": {
    "response_id": {"type": "string"},
    "request_id": {"type": "string"},
    "created_at": {"type": "string"},
    "dry_run": {"type": "boolean", "const": true},
    "provider": {"type": "string", "const": "openrouter"},
    "model_id": {"type": ["string", "null"]},
    "stage": {"type": "string"},
    "status": {"type": "string", "enum": ["planned", "skipped", "denied", "mock_success", "mock_error"]},
    "output": {"type": "object"},
    "usage": {"type": "object"},
    "cost": {"type": "object"},
    "budget_status": {"type": "string"},
    "processing_allowed": {"type": "boolean"},
    "manual_required": {"type": "boolean"},
    "error": {"type": ["object", "null"]},
    "redaction": {"type": "object"},
    "metadata": {"type": "object"}
  },
  "additionalProperties": true
}
