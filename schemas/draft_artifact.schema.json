{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CNIDraftArtifact",
  "type": "object",
  "required": [
    "artifact_id",
    "created_at",
    "artifact_type",
    "path",
    "draft_only",
    "requires_human_approval",
    "external_delivery_sent",
    "source_run_id",
    "redaction",
    "notes"
  ],
  "properties": {
    "artifact_id": {"type": "string"},
    "created_at": {"type": "string"},
    "artifact_type": {"type": "string", "enum": ["markdown_brief", "json_brief", "run_manifest"]},
    "path": {"type": "string"},
    "draft_only": {"type": "boolean", "const": true},
    "requires_human_approval": {"type": "boolean", "const": true},
    "external_delivery_sent": {"type": "boolean", "const": false},
    "source_run_id": {"type": "string"},
    "redaction": {"type": "object"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
