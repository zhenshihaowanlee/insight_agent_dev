{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SourceItem",
  "type": "object",
  "required": [
    "id",
    "title",
    "source_type",
    "source_rank",
    "relevance",
    "deep_read_decision",
    "provenance"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "local_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "title": {
      "type": "string"
    },
    "source_type": {
      "type": "string",
      "enum": [
        "paper",
        "standard",
        "rfc",
        "whitepaper",
        "technical_report",
        "lab_update",
        "product_spec",
        "patent",
        "open_source_project",
        "news",
        "unknown"
      ]
    },
    "source_rank": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D",
        "unknown"
      ]
    },
    "domain": {
      "type": [
        "string",
        "null"
      ]
    },
    "discovered_at": {
      "type": "string"
    },
    "relevance": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low",
        "Unknown"
      ]
    },
    "deep_read_decision": {
      "type": "string",
      "enum": [
        "High",
        "Medium",
        "Low",
        "Reject"
      ]
    },
    "hash": {
      "type": [
        "string",
        "null"
      ]
    },
    "rationale": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    }
  },
  "additionalProperties": true
}