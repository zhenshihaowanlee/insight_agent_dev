{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ZYWPreSendReview",
  "type": "object",
  "required": [
    "review_id",
    "created_at",
    "source_email_draft_id",
    "source_email_draft_manifest",
    "source_brief_markdown",
    "dry_run",
    "reviewer_panel",
    "overall_decision",
    "approval_state",
    "evidence_skeptic_review",
    "constraint_review",
    "delivery_safety_review",
    "executive_readability_review",
    "budget_runtime_boundary_review",
    "hard_rule_violations",
    "required_fixes",
    "optional_improvements",
    "runtime_boundary",
    "redaction",
    "validation",
    "notes"
  ],
  "properties": {
    "review_id": {"type": "string"},
    "created_at": {"type": "string"},
    "source_email_draft_id": {"type": "string"},
    "source_email_draft_manifest": {"type": "string"},
    "source_brief_markdown": {"type": "string"},
    "dry_run": {"type": "boolean", "const": true},
    "reviewer_panel": {"type": "array"},
    "overall_decision": {"type": "string", "enum": ["ready_for_human_review", "needs_revision", "blocked"]},
    "approval_state": {"type": "object"},
    "evidence_skeptic_review": {"type": "object"},
    "constraint_review": {"type": "object"},
    "delivery_safety_review": {"type": "object"},
    "executive_readability_review": {"type": "object"},
    "budget_runtime_boundary_review": {"type": "object"},
    "hard_rule_violations": {"type": "array"},
    "required_fixes": {"type": "array"},
    "optional_improvements": {"type": "array"},
    "runtime_boundary": {"type": "object"},
    "redaction": {"type": "object"},
    "validation": {"type": "object"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
