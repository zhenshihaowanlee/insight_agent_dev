{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CNILiteratureAnalysis",
  "type": "object",
  "required": [
    "analysis_id",
    "source_id",
    "title",
    "domain",
    "source_tier",
    "source_type",
    "body_is_untrusted",
    "risk_flags",
    "triage_summary",
    "basic_info",
    "one_sentence_conclusion",
    "problem_background",
    "core_idea",
    "contributions",
    "mechanism",
    "process_constraints",
    "constraint_findings",
    "constraint_dependency_analysis",
    "degraded_process_counterfactual",
    "network_impact_vector",
    "evidence_quality",
    "comparison_with_existing_technology",
    "hidden_assumptions_and_risks",
    "security_and_operations_impact",
    "reproducibility",
    "technical_insights",
    "strategic_significance",
    "score",
    "recommended_action",
    "follow_up_validation_experiments",
    "conclusion_strength",
    "quality_gate_results",
    "guardrail_notes"
  ],
  "properties": {
    "analysis_id": {
      "type": "string"
    },
    "source_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "domain": {
      "type": "string"
    },
    "source_tier": {
      "type": "string"
    },
    "body_is_untrusted": {
      "type": "boolean",
      "const": true
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "triage_summary": {
      "type": "object"
    },
    "basic_info": {
      "type": "object"
    },
    "one_sentence_conclusion": {
      "type": "string"
    },
    "problem_background": {
      "type": "string"
    },
    "core_idea": {
      "type": "string"
    },
    "contributions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mechanism": {
      "type": "object"
    },
    "process_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "type",
          "explicitly_stated",
          "performance_impact",
          "hardness",
          "degradation_consequence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "explicitly_stated": {
            "type": "boolean"
          },
          "performance_impact": {
            "type": "string"
          },
          "hardness": {
            "type": "string",
            "enum": [
              "hard",
              "semi-hard",
              "soft",
              "unknown"
            ]
          },
          "degradation_consequence": {
            "type": "string"
          }
        }
      }
    },
    "constraint_findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "constraint_dependency_analysis": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "degraded_process_counterfactual": {
      "type": "object",
      "required": [
        "verdict",
        "conditions",
        "failure_modes",
        "compensation_mechanisms"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": [
            "yes",
            "no",
            "conditional",
            "unknown"
          ]
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "compensation_mechanisms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "network_impact_vector": {
      "type": "object",
      "required": [
        "latency",
        "jitter_ipdv",
        "bandwidth_capacity",
        "reliability",
        "security",
        "operations",
        "ber_error",
        "scalability",
        "cost_power"
      ],
      "additionalProperties": {
        "type": "object",
        "required": [
          "impact",
          "evidence",
          "risk"
        ],
        "properties": {
          "impact": {
            "type": "string",
            "enum": [
              "++",
              "+",
              "0",
              "-",
              "--",
              "?"
            ]
          },
          "evidence": {
            "type": "string"
          },
          "risk": {
            "type": "string"
          }
        }
      }
    },
    "evidence_quality": {
      "type": "object"
    },
    "comparison_with_existing_technology": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "hidden_assumptions_and_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "security_and_operations_impact": {
      "type": "object"
    },
    "reproducibility": {
      "type": "object"
    },
    "technical_insights": {
      "type": "object"
    },
    "strategic_significance": {
      "type": "string"
    },
    "score": {
      "type": "object",
      "required": [
        "problem_importance",
        "core_innovation",
        "evidence_strength",
        "process_constraint_robustness",
        "network_impact_net_value",
        "deployability",
        "strategic_relevance",
        "total_score",
        "score_explanation"
      ]
    },
    "recommended_action": {
      "type": "string",
      "enum": [
        "S",
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "follow_up_validation_experiments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conclusion_strength": {
      "type": "string",
      "enum": [
        "strong",
        "moderate",
        "weak"
      ]
    },
    "quality_gate_results": {
      "type": "object"
    },
    "guardrail_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source": {
      "type": "object"
    },
    "innovation_points": {
      "type": "array"
    },
    "constraints": {
      "type": "array"
    },
    "constraint_dependency": {
      "type": "array"
    },
    "comparison_to_existing": {
      "type": "array"
    },
    "security_and_operations": {
      "type": "object"
    },
    "insights": {
      "type": "object"
    },
    "strategic_meaning": {
      "type": "string"
    },
    "follow_up_experiments": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
