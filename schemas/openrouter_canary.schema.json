{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenRouterCanaryRun",
  "type": "object",
  "required": [
    "canary_run_id",
    "created_at",
    "dry_run",
    "real_call_requested",
    "real_call_executed",
    "manual_approval",
    "provider",
    "internal_model_id",
    "api_model_slug",
    "stage",
    "request",
    "response",
    "usage",
    "cost",
    "ledger_event",
    "runtime_boundary",
    "validation",
    "notes"
  ],
  "properties": {
    "canary_run_id": {"type": "string"},
    "created_at": {"type": "string"},
    "dry_run": {"type": "boolean"},
    "real_call_requested": {"type": "boolean"},
    "real_call_executed": {"type": "boolean"},
    "manual_approval": {
      "type": "object",
      "required": ["real_call_flag", "allow_network_flag", "confirm_charge_flag", "max_cost_usd", "manual_override"]
    },
    "provider": {"type": "string", "const": "openrouter"},
    "internal_model_id": {"type": "string"},
    "api_model_slug": {"type": "string"},
    "stage": {"type": "string"},
    "request": {"type": "object"},
    "response": {
      "type": "object",
      "properties": {
        "choices": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "message": {
                "type": "object",
                "properties": {
                  "content_redacted": {"type": "boolean", "const": true},
                  "reasoning_redacted": {"type": "boolean", "const": true},
                  "reasoning_details_redacted": {"type": "boolean", "const": true},
                  "content_sha256": {"type": "string"},
                  "reasoning_sha256": {"type": "string"},
                  "reasoning_details_sha256": {"type": "string"},
                  "content_length": {"type": "integer"},
                  "reasoning_length": {"type": "integer"},
                  "reasoning_details_length": {"type": "integer"}
                }
              }
            }
          }
        }
      }
    },
    "usage": {
      "type": "object",
      "properties": {
        "estimate_under_predicted": {"type": "boolean"},
        "estimate_error_ratio": {"type": ["number", "null"]}
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "cost_estimate_source": {"type": "string"},
        "actual_cost_source": {"type": "string"},
        "audit_cost_usd": {"type": ["number", "null"]}
      }
    },
    "ledger_event": {"type": "object"},
    "runtime_boundary": {"type": "object"},
    "validation": {"type": "object"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
