{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ZYWFullPaperAnalysisRun",
  "type": "object",
  "required": [
    "analysis_level",
    "one_shot_fulltext_attempt",
    "extracted_char_count",
    "included_char_count",
    "estimated_input_tokens",
    "rough_estimated_input_tokens",
    "conservative_estimated_input_tokens",
    "actual_input_tokens",
    "requested_max_output_tokens",
    "actual_output_tokens",
    "actual_input_over_max_input_hard",
    "expected_actual_input_safe",
    "require_schema_valid_output",
    "model_cni_schema_valid",
    "raw_model_cni_schema_valid",
    "normalized_cni_schema_valid",
    "normalization_applied",
    "normalization_required",
    "full_text_not_really_sent",
    "analysis_too_short_for_cni",
    "cni_sections_present",
    "cni_section_count",
    "redaction",
    "runtime_boundary",
    "artifact_paths"
  ],
  "properties": {
    "analysis_level": {"type": "string"},
    "one_shot_fulltext_attempt": {"type": "boolean", "const": true},
    "extracted_char_count": {"type": "integer"},
    "included_char_count": {"type": "integer"},
    "estimated_input_tokens": {"type": "integer"},
    "actual_input_tokens": {"type": ["integer", "null"]},
    "requested_max_output_tokens": {"type": "integer"},
    "actual_output_tokens": {"type": ["integer", "null"]},
    "full_text_not_really_sent": {"type": "boolean"},
    "actual_input_over_max_input_hard": {"type": "boolean"},
    "expected_actual_input_safe": {"type": "boolean"},
    "require_schema_valid_output": {"type": "boolean"},
    "model_cni_schema_valid": {"type": "boolean"},
    "normalization_required": {"type": "boolean"},
    "raw_model_cni_schema_valid": {"type": "boolean"},
    "normalized_cni_schema_valid": {"type": "boolean"},
    "normalization_applied": {"type": "boolean"},
    "normalization_audit_path": {"type": ["string", "null"]},
    "schema_failure_reason": {"type": ["string", "null"]},
    "analysis_too_short_for_cni": {"type": "boolean"},
    "cni_sections_present": {"type": "array", "items": {"type": "string"}},
    "cni_section_count": {"type": "integer"},
    "redaction": {"type": "object"},
    "runtime_boundary": {"type": "object"},
    "artifact_paths": {"type": "object"}
  },
  "additionalProperties": true
}
