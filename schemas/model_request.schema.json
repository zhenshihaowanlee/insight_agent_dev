{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenRouterModelRequest",
  "type": "object",
  "required": [
    "request_id",
    "created_at",
    "dry_run",
    "provider",
    "model_id",
    "stage",
    "budget_environment",
    "quality_priority",
    "source_id",
    "input_kind",
    "messages",
    "response_format",
    "max_input_tokens",
    "max_output_tokens",
    "reasoning_level",
    "estimated_input_tokens",
    "estimated_output_tokens",
    "estimated_cost_usd",
    "routing_decision",
    "guardrails",
    "redaction",
    "metadata"
  ],
  "properties": {
    "request_id": {"type": "string"},
    "created_at": {"type": "string"},
    "dry_run": {"type": "boolean", "const": true},
    "provider": {"type": "string", "const": "openrouter"},
    "model_id": {"type": "string"},
    "stage": {"type": "string"},
    "budget_environment": {"type": "string"},
    "quality_priority": {"type": "string"},
    "source_id": {"type": "string"},
    "input_kind": {"type": "string", "enum": ["triage", "literature_analysis", "constraint_critic", "brief_synthesis", "final_review"]},
    "messages": {"type": "array"},
    "response_format": {"type": "object"},
    "max_input_tokens": {"type": "integer"},
    "max_output_tokens": {"type": "integer"},
    "reasoning_level": {"type": "string"},
    "estimated_input_tokens": {"type": "integer"},
    "estimated_output_tokens": {"type": "integer"},
    "estimated_cost_usd": {"type": "number"},
    "routing_decision": {"type": "object"},
    "guardrails": {"type": "object"},
    "redaction": {"type": "object"},
    "metadata": {"type": "object"}
  },
  "additionalProperties": true
}
