{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ZYWEmailDraft",
  "type": "object",
  "required": [
    "email_draft_id",
    "created_at",
    "source_run_id",
    "source_brief_json",
    "source_brief_markdown",
    "draft_only",
    "requires_human_approval",
    "external_delivery_sent",
    "transport",
    "headers",
    "body",
    "attachments",
    "approval",
    "redaction",
    "runtime_boundary",
    "validation",
    "notes"
  ],
  "properties": {
    "email_draft_id": {"type": "string"},
    "created_at": {"type": "string"},
    "source_run_id": {"type": "string"},
    "source_brief_json": {"type": "string"},
    "source_brief_markdown": {"type": "string"},
    "draft_only": {"type": "boolean", "const": true},
    "requires_human_approval": {"type": "boolean", "const": true},
    "external_delivery_sent": {"type": "boolean", "const": false},
    "transport": {"type": "object"},
    "headers": {"type": "object"},
    "body": {"type": "object"},
    "attachments": {"type": "array"},
    "approval": {"type": "object"},
    "redaction": {"type": "object"},
    "runtime_boundary": {"type": "object"},
    "validation": {"type": "object"},
    "notes": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
