# Copy to .env locally. Do not commit real secrets.
OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENCLAW_HOOKS_TOKEN=replace-with-long-random-token

# Verified explicit OpenRouter model refs. Replace after `openclaw models list --provider openrouter`.
ZYW_MODEL_DISCOVERY=openrouter/<verified-low-cost-model-id>
ZYW_MODEL_ANALYSIS=openrouter/<verified-long-context-model-id>
ZYW_MODEL_CRITIC=openrouter/<verified-reasoning-model-id>
ZYW_MODEL_BRIEF=openrouter/<verified-brief-model-id>
ZYW_MODEL_FINAL_REVIEW=openrouter/<verified-premium-review-model-id>

# Local paths
ZYW_DATA_DIR=./data
ZYW_OUTPUT_DIR=./outputs
ZYW_TIMEZONE=Europe/Berlin

# Budget thresholds
ZYW_MONTHLY_BUDGET_SOFT_USD=300
ZYW_MONTHLY_BUDGET_HARD_USD=400
