{
  "policy_id": "budget-research-v1",
  "name": "Research quality budget",
  "environment": "research",
  "monthly_budget_usd": 600,
  "soft_cap_usd": 750,
  "hard_cap_usd": 900,
  "daily_document_limit": 20,
  "monthly_document_limit": 600,
  "default_brief_interval_hours": 72,
  "quality_priority": "high",
  "stage_policies": {
    "triage": {"preferred_model": "openrouter/low-cost-triage-placeholder", "fallback_model": "openrouter/low-cost-triage-placeholder", "max_input_tokens_per_item": 10000, "max_output_tokens_per_item": 1000, "reasoning_level": "low", "retry_limit": 1, "cache_eligible": true, "manual_only": false, "quality_floor": "basic"},
    "literature_analysis": {"preferred_model": "openrouter/long-context-analysis-placeholder", "fallback_model": "openrouter/balanced-analysis-placeholder", "max_input_tokens_per_item": 160000, "max_output_tokens_per_item": 16000, "reasoning_level": "high", "retry_limit": 1, "cache_eligible": true, "manual_only": false, "quality_floor": "high"},
    "constraint_critic": {"preferred_model": "openrouter/reasoning-critic-placeholder", "fallback_model": "openrouter/balanced-critic-placeholder", "max_input_tokens_per_item": 64000, "max_output_tokens_per_item": 10000, "reasoning_level": "high", "retry_limit": 1, "cache_eligible": true, "manual_only": false, "quality_floor": "high"},
    "brief_synthesis": {"preferred_model": "openrouter/high-quality-brief-placeholder", "fallback_model": "openrouter/balanced-brief-placeholder", "max_input_tokens_per_item": 256000, "max_output_tokens_per_item": 20000, "reasoning_level": "high", "retry_limit": 1, "cache_eligible": false, "manual_only": false, "quality_floor": "high"},
    "final_review": {"preferred_model": "openrouter/premium-final-review-placeholder", "fallback_model": "openrouter/high-quality-brief-placeholder", "max_input_tokens_per_item": 320000, "max_output_tokens_per_item": 24000, "reasoning_level": "high", "retry_limit": 0, "cache_eligible": false, "manual_only": true, "quality_floor": "premium"}
  },
  "priority_allocation": {"preserve_quality_for_source_tiers": ["A", "B"], "preserve_quality_for_deep_read_priority": ["High"], "reduce_volume_before_model_quality": true, "skip_low_priority_before_downgrading_high_priority": true},
  "downgrade_rules": ["watch at 70 percent soft cap", "reduce low-value volume at 80 percent", "degrade or skip C/D Low priority at 90 percent", "stop nonessential work at 100 percent", "hard stop at hard cap"],
  "alert_thresholds": [70, 80, 90, 100],
  "delivery_policy": {"draft_only": true, "requires_human_approval": true},
  "provider_policy": {"allowed_provider_prefixes": ["openrouter/"], "forbidden_provider_terms": ["codex", "coding-agent", "oauth", "@openai/codex"]}
}
